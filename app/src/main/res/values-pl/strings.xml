    <string name="cross_family_format">Rodzina %1$s</string>
    <string name="cross_family_betulaceae">Betulaceae</string>
    <string name="cross_family_asteraceae">Asteraceae</string>
    <string name="cross_oas_disclaimer">Objawy OAS są zazwyczaj łagodne (swędzenie lub mrowienie w ustach) i ograniczone do surowych pokarmów. Gotowanie zazwyczaj rozkłada białka. Skonsultuj się z alergologiem w celu uzyskania spersonalizowanej porady.</string>
    <string name="cross_foods_birch">Jabłka, gruszki, czereśnie, brzoskwinie, śliwki, kiwi, orzechy laskowe, migdały, marchew, seler, soja</string>
