    <!-- Cross-reactivity -->
    <string name="nav_cross_reactivity">Reakcje krzyżowe</string>
    <string name="cross_title">Przewodnik po reakcjach krzyżowych</string>
    <string name="cross_intro">Wiele alergii pyłkowych dzieli białka z innymi rodzajami pyłków i niektórymi pokarmami. To nazywamy reakcjami krzyżowymi. Jeśli reagujesz na jeden, możesz również reagować na inne wymienione tutaj — zjawisko znane jako Zespół Alergii Jamy Ustnej (OAS).</string>
    <string name="cross_related_pollen">Powiązane pyłki</string>
    <string name="cross_food_reactions">Krzyżowe reakcje pokarmowe (OAS)</string>
    <string name="cross_strength_strong">Silna</string>
